# syntax=docker/dockerfile:1
#
# Credential-less Kerberos/Negotiate forward proxy (local Squid -> corporate Squid).
#
# Holds NO long-term secret at runtime. The domain password lives only in a
# gpg-encrypted store; at start it is decrypted through a forwarded, dedicated
# single-key gpg-agent extra socket, piped straight into kinit to mint a Kerberos
# TGT, then discarded. A local Squid forwards everything to the corporate proxy
# (cache_peer ... login=NEGOTIATE auth-no-keytab) and authenticates with the
# *ticket* from the credential cache (KRB5CCNAME) -- never the password, never a
# keytab. The ticket is renewed from itself until the realm's renewable lifetime
# ends, then one fresh pinentry re-mints it.

FROM docker.io/library/alpine:3.21
# squid   : the forward proxy. cache_peer login=NEGOTIATE speaks Kerberos/SPNEGO
#           to the corporate proxy; Alpine builds squid against Heimdal GSSAPI.
# heimdal : kinit / klist + the same Kerberos implementation squid's GSSAPI uses,
#           so the ticket kinit mints is the one squid reads from the cache.
# gnupg   : gpg client that talks to the forwarded host agent socket.
RUN apk add --no-cache squid heimdal gnupg \
 && install -d -m 0755 /var/cache/squid /var/log/squid

ENV GNUPGHOME=/root/.gnupg
# Never let gpg spawn its own agent -- it MUST use the forwarded host socket.
RUN install -d -m 700 "$GNUPGHOME" \
 && printf 'no-autostart\ntrust-model always\n' > "$GNUPGHOME/gpg.conf"

COPY resource/squid.conf.template /etc/squid/squid.conf.template
COPY resource/entrypoint.sh       /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh

EXPOSE 3128
ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
