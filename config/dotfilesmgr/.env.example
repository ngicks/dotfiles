# dotfilesmgr configuration
#
# Copy this file to ~/.config/dotfilesmgr/.env; the server loads it on
# startup. Values already present in the real environment (for example a systemd
# `Environment=` line) take precedence over anything set here.
#
# Syntax: KEY=VALUE per line. Blank lines and `#` comments are ignored; an
# optional leading `export ` and surrounding single/double quotes are tolerated.

# Enable automatic devenv image rebuilds: when the upstream checkout advances,
# the server rebuilds the devenv image in the background. Without this the server
# only builds when a job is requested explicitly.
#
# Truthy: 1 / true / yes / on (case-insensitive). Unset or 0/false = disabled.
DOTFILES_SERVER_AUTO_BUILD=1
