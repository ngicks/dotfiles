# Copy to ~/.config/forwardproxy/forwardproxy.env on machines/networks that
# should run the forwardproxy service. Do not commit the real file.
REALM=EXAMPLE.COM
PRINCIPAL=user@EXAMPLE.COM
# Address the corporate Squid by the FQDN its Kerberos principal is built for:
# Squid asks the KDC for HTTP/UPSTREAM_HOST when authenticating (Negotiate).
UPSTREAM_HOST=proxy.example.com
UPSTREAM_PORT=8080

# Defaults are localhost-only. Widen these only when containers or LAN clients
# must use the proxy.
BIND=127.0.0.1
PORT=3128
PROXY_ACL=127.0.0.0/8

# Optional when DNS SRV records do not locate the KDC.
#KDC=kdc.example.com

# Set to 1 only while diagnosing gpg-agent/pinentry decrypt failures. This logs
# gpg status/debug lines and public key metadata, but not the decrypted secret.
#FORWARDPROXY_GPG_DEBUG=1
