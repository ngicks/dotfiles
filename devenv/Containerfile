# syntax=docker/dockerfile:1

ARG DEVENV_TAG
ARG BASE_IMAGE="localhost/devenv/nix-home-manager-env:${DEVENV_TAG}"
FROM ${BASE_IMAGE}

ARG GIT_TAG=""
ARG HTTP_PROXY=""
ARG HTTPS_PROXY=""
ARG http_proxy=${HTTP_PROXY}
ARG https_proxy=${HTTPS_PROXY}
ARG NO_PROXY=""
ARG no_proxy=${NO_PROXY}

ARG SSL_CERT_FILE="/ca-certificates.crt"
ARG NODE_EXTRA_CA_CERTS=${SSL_CERT_FILE}
ARG DENO_CERT=${SSL_CERT_FILE}
ARG NIX_SSL_CERT_FILE=${SSL_CERT_FILE}

WORKDIR /root
RUN --mount=type=secret,id=cert,target=/ca-certificates.crt \
    --mount=type=bind,target=/.dotfiles \
<<EOF
    if [ "${GIT_TAG}" = "exp" ]; then
      cp -a /.dotfiles .
    else
      git clone --depth 1 --branch v${GIT_TAG} https://github.com/ngicks/dotfiles.git ./.dotfiles
    fi 
EOF

WORKDIR /root/.dotfiles

ENV SHELL="/root/.nix-profile/bin/zsh"
ENV RUSTUP_HOME="/root/.local/share/rustup"

RUN <<EOF
    # For sshfs.nvim
    mkdir -p ~/mnt/sshfs

    # Mountpoint for the host image store (07-podman.sh); pre-created so the
    # __additional_podman-in-podman storage.conf's additionalimagestores entry
    # stays valid (an empty read-only store) when the mount is skipped.
    mkdir -p ~/.local/share/containers/host-graphroot

    mkdir -p "${XDG_CACHE_HOME:-/root/.cache}/dotfiles"
    touch "${XDG_CACHE_HOME:-/root/.cache}/dotfiles/.no_update_daily"

    export CARGO_HOME="/root/.local/share/cargo"
    rustup default stable

    export MOON_HOME="/root/.local/share/moonbit"
    mkdir -p $MOON_HOME
    curl -fsSL https://cli.moonbitlang.com/install/unix.sh | /root/.nix-profile/bin/bash
EOF

WORKDIR /root

ENV LANG=C.UTF-8

ENTRYPOINT ["/root/.nix-profile/bin/zsh"]
